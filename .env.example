# ============================================================
# Cow-Visioning — Environment Variables Reference
# Copy this file to `.env` and fill in your real values.
# NEVER commit .env with real credentials to version control.
# ============================================================

# === Server ===
PORT=3000
NODE_ENV=development

# === Database (PostgreSQL) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cow_visioning
DB_USER=cowapp
DB_PASSWORD=your_password_here

# === Session ===
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
SESSION_COOKIE_SAMESITE=lax
# Set to true in production (requires HTTPS)
SESSION_COOKIE_SECURE=false

# === CORS ===
# Comma-separated list of allowed origins. Leave empty to disable custom CORS.
CORS_ALLOWED_ORIGINS=

# === URLs ===
# Public base URL of the API (used to build absolute image URLs)
PUBLIC_API_BASE_URL=
# Base URL for serving uploaded images
IMAGE_BASE_URL=

# === Uploads ===
UPLOAD_DIR=./uploads

# === AI Service ===
AI_SERVICE_URL=http://127.0.0.1:8001
# Timeout in milliseconds for AI prediction requests
AI_TIMEOUT_MS=20000
# Set to true to embed image as base64 payload instead of file path
AI_EMBED_IMAGE_PAYLOAD=false

# AI feature toggle
AI_ENABLED=true
AI_TOOL_PRO_ENABLED=true



# Optional: name of the AI model being used (for logging/display)
AI_MODEL_NAME=

# === OpenAI Upload Tool Pro ===
# When OPENAI_API_KEY is present, uploaded images can be classified by OpenAI first.
# Local camera capture still uses the existing local AI service unless you extend it later.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_UPLOAD_REASONING_EFFORT=low
OPENAI_UPLOAD_MAX_OUTPUT_TOKENS=400
OPENAI_CHAT_MODEL=gpt-5-chat-latest
OPENAI_CHAT_REASONING_EFFORT=low
OPENAI_TIMEOUT_MS=30000
OPENAI_UPLOAD_ENABLED=true
OPENAI_CHAT_HISTORY_LIMIT=8
# GPT-5-family chat models can spend part of this budget on reasoning before visible text.
# Keep this comfortably above short-answer ranges to avoid incomplete empty responses.
OPENAI_CHAT_MAX_OUTPUT_TOKENS=1400
# Optional: override the agriculture-focused system prompt for the website assistant
OPENAI_CHAT_SYSTEM_PROMPT=
OPENAI_BLOG_DRAFT_MODEL=gpt-5-chat-latest
OPENAI_BLOG_DRAFT_REASONING_EFFORT=low
OPENAI_BLOG_DRAFT_MAX_OUTPUT_TOKENS=2200
OPENAI_BLOG_DRAFT_TIMEOUT_MS=90000
OPENAI_BLOG_IMAGE_MODEL=gpt-image-1
OPENAI_BLOG_IMAGE_SIZE=1024x1024
OPENAI_BLOG_IMAGE_TIMEOUT_MS=120000
OPENAI_BLOG_MAX_DRAFTS=4
OPENAI_BLOG_SYSTEM_PROMPT=

# === Test Database (for `npm test` only) ===
# Point this to a separate test PostgreSQL database.
# The test suite will apply schema.sql before running tests.
TEST_DATABASE_URL=postgresql://cowapp:your_password_here@localhost:5432/cow_visioning_test

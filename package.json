{
    "name": "cow-visioning",
    "version": "1.0.0",
    "description": "Dataset nhận diện hành vi bò - Upload, camera, gallery & export",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "start:ai": "python -m uvicorn ai_service.app:app --host 127.0.0.1 --port 8001",
        "test": "jest --forceExit",
        "test:coverage": "jest --forceExit --coverage"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "connect-pg-simple": "^10.0.0",
        "cors": "^2.8.6",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^8.3.1",
        "express-session": "^1.19.0",
        "multer": "^1.4.5-lts.1",
        "pg": "^8.13.1"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "nodemon": "^3.1.9",
        "supertest": "^7.2.2"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": ["**/tests/**/*.test.js"],
        "testTimeout": 60000,
        "forceExit": true,
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "server.js",
            "!**/node_modules/**",
            "!**/public/**"
        ],
        "coverageThreshold": {
            "global": {
                "lines": 50
            }
        }
    }
}
